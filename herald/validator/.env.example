# Minimal validator configuration. The root .env.example documents every Herald setting.
NETUID=69
SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
SUBTENSOR_NETWORK=finney
PORT=8092
AXON_EXTERNAL_IP=
AXON_EXTERNAL_PORT=8092
DISABLE_AUTO_UPDATE=true

WALLET_NAME=
HOTKEY_NAME=

# Configure at least one search provider identically across the validator fleet.
SERPAPI_API_KEY=
# BRAVE_API_KEY=

# Required by the 50 proxy-strategy outlets in the shipped registry.
SCRAPINGBEE_API_KEY=
HERALD_REGISTRY_PATH=herald/validator/news/outlets.json
# HERALD_REGISTRY_ENDPOINT=http://127.0.0.1:8093
# HERALD_REGISTRY_CACHE_PATH=/var/lib/herald/outlets.verified.json

# Production must use an offline-signed registry and enforce both signature and anchor.
# HERALD_REGISTRY_PUBKEY=
# HERALD_REQUIRE_SIGNED_REGISTRY=true
# HERALD_REGISTRY_AUTHORITY_HOTKEY=

# Point this at the signed brief-board validator feed.
# HERALD_BRIEFS_ENDPOINT=https://herald-api.example/api/v2/validator/briefs
# HERALD_BRIEFS_PUBKEY=
# HERALD_REQUIRE_SIGNED_BRIEFS=true
# HERALD_BRIEFS_MAX_AGE=900

# Public result publication and cross-validator claim reconciliation.
# HERALD_RESULTS_ENDPOINT=https://herald-api.example
# HERALD_RESULTS_TOKEN=

# Retry only failed miner axon responses before sealing this epoch's snapshot.
# HERALD_CLAIM_QUERY_ATTEMPTS=3
# HERALD_CLAIM_QUERY_TIMEOUT=12
# HERALD_CLAIM_QUERY_RETRY_DELAY=1
