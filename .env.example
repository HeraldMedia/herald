# ─── Wallet ──────────────────────────────────────────────────────────────────
WALLET_NAME=default
HOTKEY_NAME=default
# For docker, fill these by running: ./scripts/wallet-env.sh <wallet> <hotkey> >> .env
# HOTKEY_DATA=
# HOTKEYPUB_DATA=
# COLDKEYPUB_DATA=

# ─── Bittensor ──────────────────────────────────────────────────────────────
NETUID=69
SUBTENSOR_NETWORK=finney
# SUBTENSOR_CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# ─── Validator: outside-data + registry ──────────────────────────────────────
SERPAPI_API_KEY=
# Optional second providers enable a quorum (cross-validator robustness)
# SCRAPINGBEE_API_KEY=
# BRAVE_API_KEY=
# Number of providers that must agree (clamped to how many are configured). This and the
# provider set above are CONSENSUS parameters: configure them IDENTICALLY on every validator,
# or a missing key relaxes the quorum and changes which provider supplies published_ts.
HERALD_QUORUM_THRESHOLD=1
# Outlet registry (validators verify the ed25519 signature when a pubkey is set)
HERALD_REGISTRY_PATH=herald/validator/news/outlets.seed.json
# HERALD_REGISTRY_PUBKEY=
# Refuse to load an unsigned registry (recommended in production)
# HERALD_REQUIRE_SIGNED_REGISTRY=true
# On-chain anchor: hotkey that committed HRLDREG|version|hash|block (validators verify the loaded list matches)
# HERALD_REGISTRY_AUTHORITY_HOTKEY=
# Bond size: alpha required per USD of a claim's expected reward (set near 1/alpha_price after pilot)
HERALD_BOND_ALPHA_PER_USD=1.0
# LLM judgement tier — must be set IDENTICALLY across validators or weights diverge.
# Enabling it also REQUIRES a pinned HERALD_REF_MODEL_ID (else it stays rules-only).
HERALD_USE_LLM_JUDGE=false
# HERALD_REF_MODEL_ID=
# Persistence: consecutive confirmed-dead epochs before clawback+slash; vesting expiry grace;
# and the max plausible commit->publication gap (rejects implausible future dates).
HERALD_DEAD_CONFIRM_EPOCHS=2
HERALD_VEST_GRACE_EPOCHS=30
HERALD_MAX_PLACEMENT_DAYS=90
# Publish verified articles to the brief board for the public page (optional)
# HERALD_RESULTS_ENDPOINT=http://localhost:8093
# HERALD_RESULTS_TOKEN=

# ─── Brief board service ──────────────────────────────────────────────────────
BRIEF_BOARD_PORT=8093
HERALD_BRIEF_STORE=brief_store.json
HERALD_RESULT_STORE=result_store.json
HERALD_REVEAL_STORE=reveal_store.json
# Working DRAFT of the outlet registry that operators stage via /admin/registry/* (and the
# console). Unsigned by construction — export it and sign OFFLINE with `herald-registry`, then
# publish the signed file as HERALD_REGISTRY_PATH. The signing key never touches this service.
HERALD_REGISTRY_DRAFT_STORE=registry_draft.json
# Display mirror of on-chain disputes (HRLDDIS) for the console — NOT authoritative (validators
# read disputes from chain). GET /disputes is public; POST /disputes is gated by HERALD_DISPUTES_TOKEN.
HERALD_DISPUTE_STORE=dispute_store.json
# Display mirror of on-chain brief funding (HRLDFUND) — who funds which brief + α held; the operator
# sets the brief boost from it. GET /funding is public; POST /funding is gated by HERALD_FUNDING_TOKEN.
HERALD_FUNDING_STORE=funding_store.json
# The mutating endpoints (/admin/*, /results, /reveals) are DISABLED until their token is set —
# a tokenless public deployment can't be posted fake briefs or fake "verified" articles.
# HERALD_ADMIN_TOKEN=
# Token validators present to POST /results (set the same value on validators)
# HERALD_RESULTS_TOKEN=
# Token for /reveals (POST from a trusted dashboard, GET by `herald-miner pull-reveals`).
# The nonce is a secret, so /reveals is gated on read AND write. Only set the matching
# NEXT_PUBLIC_HERALD_REVEALS_TOKEN on a TRUSTED/internal dashboard, never a public site.
# HERALD_REVEALS_TOKEN=
# Token to POST the dispute display mirror (POST /disputes). The console BFF forwards it; GET stays
# public since disputes are on-chain. Mirror is UX only — not used for scoring.
# HERALD_DISPUTES_TOKEN=
# Token to POST the funding display mirror (POST /funding). The console BFF forwards it; GET public.
# Mirror is UX only — the validator reads the brief's signed boost, set by the operator from holdings.
# HERALD_FUNDING_TOKEN=
# Local dev only: allow the mutating endpoints with no token (never set this in production).
# HERALD_ALLOW_OPEN_WRITES=false
# Allowed CORS origins for the public read API (the landing page fetches it cross-origin).
# Comma-separated; unset = allow all (fine for public read-only data). e.g.:
# HERALD_CORS_ORIGINS=https://herald.network,https://www.herald.network

# ─── Miner ────────────────────────────────────────────────────────────────────
# Validators read open briefs from this endpoint (point at your brief board)
# HERALD_BRIEFS_ENDPOINT=http://localhost:8093/api/v2/validator/briefs
HERALD_CLAIM_STORE=claims.json

# ─── Client-funded briefs: brief signing (see FUNDING_DESIGN.md) ──────────────
# A brief's `boost` directs emissions (capped at HERALD_FUND_BOOST_MAX, default 3×, on every
# validator). To make the boost operator-attributable, the brief board signs the validator feed:
#   • Board (this service): HERALD_BRIEFS_PRIVKEY = Ed25519 private key (hex). Online key — gives
#     tamper-evidence + attribution; a board compromise is still bounded by the 3× clamp. Generate
#     with `herald-registry gen-key`.
# HERALD_BRIEFS_PRIVKEY=
#   • Validators: HERALD_BRIEFS_PUBKEY = the matching public key (hex) to verify the feed.
#     HERALD_REQUIRE_SIGNED_BRIEFS=true rejects unsigned feeds. Unset pubkey = unsigned mode.
# HERALD_BRIEFS_PUBKEY=
# HERALD_REQUIRE_SIGNED_BRIEFS=true
# Max boost any brief can apply, enforced in scoring on every validator (consensus rail).
# HERALD_FUND_BOOST_MAX=3.0

# ─── Optional ─────────────────────────────────────────────────────────────────
# WANDB_API_KEY=
# DISABLE_AUTO_UPDATE=true
