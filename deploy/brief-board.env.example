# Legacy JSON Brief Board configuration for development or one-time migration only. Production
# uses herald-backend with Postgres. Never share a neuron wallet env file with this service.

HERALD_ENABLE_LEGACY_BRIEF_BOARD=true
HERALD_PRODUCTION=false

HERALD_ALLOW_OPEN_WRITES=false

# Independent high-entropy tokens for each write surface.
HERALD_ADMIN_TOKEN=
HERALD_RESULTS_TOKEN=
HERALD_REVEALS_TOKEN=
HERALD_DISPUTES_TOKEN=
HERALD_FUNDING_TOKEN=

# Online Ed25519 brief-feed signer. Use a distinct key from the offline registry signer.
HERALD_BRIEFS_PRIVKEY=

# Public service policy.
HERALD_CORS_ORIGINS=https://herald.network
HERALD_MAX_RESULTS=100000

# Public signed registry used for board statistics; no registry private key belongs here.
HERALD_REGISTRY_PATH=/secure/config/outlets.signed.json
